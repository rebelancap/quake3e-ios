+// visionOS 3D stereo state (patch 0006). vk_stereo3d_eye: 0=off (normal 2D), 1=left,
+// 2=right — set per off-screen frame by the shell. vk_stereo3d_sep: parallax divisor
+// (larger = subtler depth; IPD/comfort control). tr_main.c reads both for the view
+// offset. vk_stereo3d_eye_done latches which eye color_image holds after each frame, so
+// the immersive compositor copies it into the matching per-eye texture (on its own
+// Metal queue — see VK_Get3DEyeDone).
+int vk_stereo3d_eye = 0;
+int vk_stereo3d_eye_done = 0;
+int vk_stereo3d_frames = 0;
+float vk_stereo3d_sep = 20.0f;   // parallax divisor; larger = gentler depth (comfort)
+
