 static void vk_alloc_attachments( void )
 {
 	VkImageViewCreateInfo view_desc;
@@ -7590,6 +7602,17 @@ void vk_end_frame( void )
 
 	vk_end_render_pass();
 
+	// visionOS 3D stereo (patch 0006): latch which eye this finished off-screen frame
+	// holds, so the immersive compositor can copy color_image into the matching per-eye
+	// Metal texture (the copy happens on the compositor's own Metal queue, avoiding the
+	// cross-queue hazard a Vulkan-side blit here would create). vk_stereo3d_frames counts
+	// minimized renders — a liveness signal (is color_image actually being updated?).
+	if ( ri.CL_IsMinimized() ) {
+		vk_stereo3d_frames++;
+		if ( vk_stereo3d_eye >= 1 && vk_stereo3d_eye <= 2 )
+			vk_stereo3d_eye_done = vk_stereo3d_eye;
+	}
+
 	VK_CHECK( qvkEndCommandBuffer( vk.cmd->command_buffer ) );
 
 	submit_info.sType = VK_STRUCTURE_TYPE_SUBMIT_INFO;
@@ -7724,6 +7747,28 @@ void *VK_Get3DColorMTLTexture( void )
 	return mtlTexture;
 }
 
+// visionOS 3D stereo (patch 0006). The shell selects the eye for each off-screen frame
+// and tunes the parallax separation (IPD/comfort); VK_Get3DColorMTLTexture returns the
+// just-rendered frame and VK_Get3DEyeDone reports which eye it holds, so the immersive
+// compositor copies it into the matching per-eye texture on its own Metal queue.
+void VK_Set3DEye( int eye )          { vk_stereo3d_eye = eye; }
+void VK_Set3DSeparation( float sep ) { if ( sep > 0.1f ) vk_stereo3d_sep = sep; }
+int  VK_Get3DEye( void )             { return vk_stereo3d_eye; }
+int  VK_Get3DEyeDone( void )         { return vk_stereo3d_eye_done; }
+int  VK_Get3DFrames( void )          { return vk_stereo3d_frames; }
+
+// The engine's MoltenVK MTLCommandQueue. The immersive compositor renders on THIS same
+// queue so its copy/sample of color_image serializes with the engine's frame renders —
+// Metal hazard-tracks the shared texture, avoiding the cross-queue hang a separate queue
+// caused. id<MTLCommandQueue>* is a plain pointer, so declare it void* to stay pure C.
+extern void vkGetMTLCommandQueueMVK( VkQueue queue, void *pMTLQueue );
+void *VK_GetMTLCommandQueue( void )
+{
+	void *mtlQueue = NULL;
+	vkGetMTLCommandQueueMVK( vk.queue, &mtlQueue );
+	return mtlQueue;
+}
