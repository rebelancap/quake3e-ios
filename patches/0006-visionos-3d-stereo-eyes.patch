+#ifdef USE_VULKAN
+extern int   vk_stereo3d_eye;   // visionOS 3D stereo (patch 0006): 0=off,1=left,2=right
+extern float vk_stereo3d_sep;   // parallax divisor (larger = subtler depth)
+#endif
+
 void R_SetupProjection( viewParms_t *dest, float zProj, qboolean computeFrustum )
 {
 	float	xmin, xmax, ymin, ymax;
@@ -578,6 +583,19 @@ void R_SetupProjection( viewParms_t *dest, float zProj, qboolean computeFrustum
 			stereoSep = 0;
 	}
 
+#ifdef USE_VULKAN
+	// visionOS 3D stereo (patch 0006): the shell renders alternating eyes off-screen
+	// (STEREO_CENTER frames) and asks for a parallax offset via vk_stereo3d_eye. Apply
+	// the same asymmetric-frustum shift the desktop stereo path uses.
+	if ( stereoSep == 0 && vk_stereo3d_eye )
+	{
+		if ( vk_stereo3d_eye == 1 )
+			stereoSep = zProj / vk_stereo3d_sep;
+		else if ( vk_stereo3d_eye == 2 )
+			stereoSep = zProj / -vk_stereo3d_sep;
+	}
+#endif
+
 	ymax = zProj * tan(dest->fovY * M_PI / 360.0f);
 	ymin = -ymax;
 
