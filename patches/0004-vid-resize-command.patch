+static void vk_set_render_scale( void );
+
+// Lightweight window resize for externally-windowed ports (visionOS). The QVM
+// cgame caches glconfig at CG_Init and never refetches it, so CHANGING the render
+// resolution here leaves it drawing at the old size — crop when the window
+// shrinks, black when it grows; only a full vid_restart re-inits it. Instead keep
+// the render resolution (glConfig) FIXED and move only the window/swapchain size,
+// then let the engine's built-in render-scale blit the fixed-res render to fill
+// the new window (aspect-preserved via r_renderScale). No cgame re-init, no
+// VM/map/texture reload — just a swapchain recreate.  <width,height> is the new
+// window (drawable) size in pixels.
+void vk_resize( int width, int height )
+{
+	if ( width < 16 || height < 16 )
+		return;
+	if ( width == gls.windowWidth && height == gls.windowHeight )
+		return;
+	gls.windowWidth = width;
+	gls.windowHeight = height;
+	// recompute the present-blit scale + letterbox for the new window vs the
+	// (unchanged) render resolution, then bake it into recreated pipelines.
+	vk.blitFilter = GL_NEAREST;
+	vk.windowAdjusted = qfalse;
+	vk.blitX0 = vk.blitY0 = 0;
+	vk_set_render_scale();
+	vk_restart_swapchain( "vk_resize", VK_SUCCESS );
+}
+
